{
  "name": "@commercetools/processors",
  "version": "0.0.0",
  "mcpName": "io.github.commercetools/processors",
  "homepage": "https://github.com/commercetools/processors",
  "description": "A collection of output processors for commercetools MCP server",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "bin": "dist/index.js",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "VERSION",
    "package.json"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prebuild": "pnpm run clean",
    "dev:build": "tsup --env.NODE_ENV dev",
    "build": "tsup",
    "clean": "rm -rf dist",
    "lint": "eslint \"./**/*.ts*\"",
    "prettier": "prettier './**/*.{js,ts,md,html,css}' --write",
    "prettier-check": "prettier './**/*.{js,ts,md,html,css}' --check",
    "test": "jest",
    "validate": "pnpm run lint --fix && pnpm run prettier && pnpm run test"
  },
  "packageManager": "pnpm@9.11.0",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "dotenv": "17.2.1",
    "qs": "6.14.0"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "commercetools",
    "field-filtering",
    "transformations",
    "transform",
    "tools"
  ],
  "author": "commercetools GmbH <info@commercetools.com> (https://commercetools.com)",
  "repository": {
    "url": "https://github.com/commercetools/processors"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/compat": "^1.2.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.4",
    "@types/qs": "^6.14.0",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "concurrently": "^9.2.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",

    "@types/express": "^5.0.3",
    "eslint": "^9.17.0"
  }
}
